# 多测试页面共用百炼配置（Vite 环境变量必须使用 VITE_ 前缀）
VITE_AI_PROVIDER=glm
VITE_BAILIAN_API_KEY=sk-b1459da96dc74ab7826b0cb5953c5c89

# 模型与服务配置
VITE_BAILIAN_MODEL=qwen3.5-27b
VITE_BAILIAN_ENDPOINT=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions
VITE_BAILIAN_MODEL_FALLBACKS=qwen3-14b,qwen-mt-flash,qwen3-vl-plus-2025-09-23,qwen-vl-plus-0102,qwen-plus-2025-09-11,qwen3-vl-flash-2026-01-22,qwen-plus-latest,qwen3.6-plus

# GLM 配置：
# 1. 填写 VITE_GLM_API_KEY
# 2. 将 VITE_AI_PROVIDER 改为 glm 即可切换
# 3. 当 GLM 调用失败时，会自动回退到 Qwen 的模型序列
# 4. 如需切回千问，将 VITE_AI_PROVIDER 改回 qwen
VITE_GLM_ENDPOINT=https://open.bigmodel.cn/api/paas/v4/chat/completions
VITE_GLM_MODEL=glm-4.5-air
VITE_GLM_API_KEY=7d3c6b5d1e7b4a4db9b0a8f20d404ddf.ZX9y3n0ueEDwUrsJ
# VITE_GLM_MODEL_FALLBACKS=
# VITE_GLM_MODEL_PRIORITY=glm-4.5-air

# 被动反馈开关：控制答题完成后自动弹出的评价弹窗（Like / Suggestion）
# 设置为 false 就关闭被动弹窗
VITE_ENABLE_PASSIVE_FEEDBACK=false

# 主动反馈开关：控制页面中「来唠两句」、「我有意见」等主动入口的显示
# 设置为 false 就隐藏所有主动评价入口
VITE_ENABLE_ACTIVE_FEEDBACK=false 


# VITE_BAILIAN_MODEL=qwen-mt-flash
