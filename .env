# 多测试页面共用百炼配置（Vite 环境变量必须使用 VITE_ 前缀）
VITE_BAILIAN_API_KEY=sk-b1459da96dc74ab7826b0cb5953c5c89

# 模型与服务配置
VITE_BAILIAN_MODEL=qwen3-8b
VITE_BAILIAN_ENDPOINT=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions
VITE_BAILIAN_MODEL_FALLBACKS=qwen3.5-27b,qwen3-14b,qwen-mt-flash,qwen3-vl-plus-2025-09-23,qwen-vl-plus-0102,qwen-plus-2025-09-11,qwen3-vl-flash-2026-01-22,qwen-plus-latest

# 被动反馈开关：控制答题完成后自动弹出的评价弹窗（Like / Suggestion）
# 设置为 false 就关闭被动弹窗
VITE_ENABLE_PASSIVE_FEEDBACK=false

# 主动反馈开关：控制页面中「来唠两句」、「我有意见」等主动入口的显示
# 设置为 false 就隐藏所有主动评价入口
VITE_ENABLE_ACTIVE_FEEDBACK=false 


# VITE_BAILIAN_MODEL=qwen-mt-flash
