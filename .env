# -----------------------------
# 授权系统（前端接入）
# -----------------------------
# 必填：独立授权服务地址（例如 https://asking-license-server.vercel.app）
VITE_LICENSE_API_BASE_URL=https://asking-license-server.vercel.app

# 必填：middleware 运行时访问的授权服务地址。建议与 VITE_LICENSE_API_BASE_URL 保持一致。
LICENSE_API_BASE_URL=https://asking-license-server.vercel.app

# 必填：会话签名密钥。该值需与授权服务项目保持一致，供 middleware 校验授权 Cookie。
