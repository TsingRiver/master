# Speed Insights 开关（可选）：
# 留空或 auto = 自动识别部署环境（推荐）
# true = 强制开启，false = 强制关闭
# 注意：本地开发模式（npm run dev）会被代码硬性禁用，此项仅对生产构建生效。
# VITE_ENABLE_SPEED_INSIGHTS=auto

# 可选：采样率（0~1）。不设置时由 SDK 使用默认值。
# VITE_SPEED_INSIGHTS_SAMPLE_RATE=1

# 可选：自定义上报端点（通常无需设置）
# VITE_SPEED_INSIGHTS_ENDPOINT=

# -----------------------------
# 授权系统（前端接入）
# -----------------------------
# 必填：独立授权服务地址（例如 https://asking-license-server.vercel.app）
# VITE_LICENSE_API_BASE_URL=

# 必填：middleware 运行时访问的授权服务地址。建议与 VITE_LICENSE_API_BASE_URL 保持一致。
# LICENSE_API_BASE_URL=

# 必填：会话签名密钥。该值需与授权服务项目保持一致，供 middleware 校验授权 Cookie。
# LICENSE_SESSION_SECRET=

# -----------------------------
# AI 提供方切换配置（可选）
# -----------------------------
# 可选：当前启用的 AI 提供方。
# qwen = 阿里百炼 / 千问
# glm = 智谱 AI / GLM
# 不填写时默认 qwen。
# 当设置为 glm 且 GLM 调用失败时，若 Qwen 配置可用，会自动回退到 Qwen。
# VITE_AI_PROVIDER=qwen

# 可选：Qwen 与 GLM 共用的超时 / 重试配置。
# 若未设置，则优先回退到历史 `VITE_BAILIAN_*` 同名配置。
# VITE_AI_TIMEOUT_MS=26000
# VITE_AI_RETRY_COUNT=1
# VITE_AI_RETRY_DELAY_MS=650
# VITE_AI_ENABLE_THINKING=false
# VITE_AI_STREAM=true

# -----------------------------
# Qwen（阿里百炼）配置（可选）
# -----------------------------
# 必填：百炼 API Key（不要提交真实密钥到仓库）
# VITE_BAILIAN_API_KEY=

# 可选：接口地址（通常保持默认）
# VITE_BAILIAN_ENDPOINT=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions

# 可选：主模型（默认 qwen3.5-plus-2026-02-15）
# VITE_BAILIAN_MODEL=qwen3.5-plus-2026-02-15

# 可选：备用模型列表（逗号分隔，主模型失败时自动降级）
# VITE_BAILIAN_MODEL_FALLBACKS=qwen3.5-plus,qwen-flash,qwen-turbo

# 可选：完整优先级列表（优先级高于主模型+备用模型）
# 示例：主模型不可用时按顺序自动切换。
# VITE_BAILIAN_MODEL_PRIORITY=qwen3.5-plus-2026-02-15,qwen3.5-plus,qwen-turbo

# 可选：思考模式与流式输出（默认：关闭思考 + 开启流式）
# VITE_BAILIAN_ENABLE_THINKING=false
# VITE_BAILIAN_STREAM=true

# 可选：超时与重试（兼容旧配置，建议优先使用上方 `VITE_AI_*`）
# VITE_BAILIAN_TIMEOUT_MS=26000
# VITE_BAILIAN_RETRY_COUNT=1
# VITE_BAILIAN_RETRY_DELAY_MS=650

# -----------------------------
# GLM（智谱 AI）配置（可选）
# -----------------------------
# 切换到 GLM：
# 1. 填写 `VITE_GLM_API_KEY`
# 2. 将 `VITE_AI_PROVIDER` 改为 glm
# 3. 若 GLM 调用失败，系统会自动按 Qwen 模型顺序回退
# 切回 Qwen：将 `VITE_AI_PROVIDER` 改回 qwen 即可

# 必填：智谱 API Key（不要提交真实密钥到仓库）
# VITE_GLM_API_KEY=

# 可选：OpenAI 兼容接口地址（通常保持默认）
# VITE_GLM_ENDPOINT=https://open.bigmodel.cn/api/paas/v4/chat/completions

# 可选：主模型（默认 glm-4.5-air）
# VITE_GLM_MODEL=glm-4.5-air

# 可选：备用模型列表（逗号分隔）
# VITE_GLM_MODEL_FALLBACKS=

# 可选：完整优先级列表（优先级高于主模型+备用模型）
# VITE_GLM_MODEL_PRIORITY=glm-4.5-air

# 可选：思考模式与流式输出（默认：关闭思考 + 开启流式）
# VITE_GLM_ENABLE_THINKING=false
# VITE_GLM_STREAM=true

# -----------------------------
# 意见反馈模块配置
# -----------------------------
# 可选：临时关闭答题完成后页面被动弹窗 (true/false)
VITE_ENABLE_PASSIVE_FEEDBACK=false

# 可选：临时关闭页面主动意见反馈区域入口 (true/false)
VITE_ENABLE_ACTIVE_FEEDBACK=false
